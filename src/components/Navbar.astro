---
import logoSrc from '../assets/icons/logo_blanc.svg?url';
interface Props {
  page?: 'home' | 'game' | 'inner';
  activePath?: string;
}
const { page = 'home', activePath = '' } = Astro.props;

const links = [
  { href: '/regles', label: 'Règles' },
  { href: '/histoire', label: 'Histoire' },
  { href: '/patterns', label: 'Patterns' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 h-16 border-b border-border bg-bg/80 backdrop-blur-md transition-all duration-300">
  <a href="/" class="flex items-center gap-2">
    <img src={logoSrc} alt="LIFE" class="h-7 w-auto" />
  </a>

  {page === 'game' ? (
    <a href="/" class="flex items-center gap-2 border border-border text-muted px-4 py-1.5 rounded-sm hover:border-text hover:text-text transition-all duration-300 font-mono text-sm">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Accueil
    </a>
  ) : (
    <>
      <ul class="hidden md:flex items-center gap-8 text-sm font-mono text-muted">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class={`hover:text-text transition-colors duration-300 ${activePath === link.href ? 'text-text' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/jeu" class="flex items-center gap-2 border border-accent text-accent px-4 py-1.5 rounded-sm hover:bg-accent hover:text-bg transition-all duration-300 font-semibold">
            Simuler
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </li>
      </ul>
      <button id="mobile-menu-btn" class="md:hidden text-muted hover:text-text">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </>
  )}
</nav>

{page !== 'game' && (
  <div id="mobile-menu" class="fixed top-16 left-0 right-0 z-40 bg-bg/95 backdrop-blur-md border-b border-border hidden flex-col gap-4 p-6 font-mono text-sm text-muted">
    {links.map(link => (
      <a href={link.href} class="hover:text-text transition-colors">{link.label}</a>
    ))}
    <a href="/jeu" class="text-accent font-semibold">Simuler →</a>
  </div>
)}

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
</script>
