---
import logoSrc from '../assets/icons/logo_blanc.svg?url';
---
<footer class="border-t border-border mt-32 py-12 px-6 md:px-12">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-10">
      <div>
        <img src={logoSrc} alt="LIFE" class="h-7 w-auto mb-3" />
        <p class="text-muted text-sm font-mono">Le Jeu de la Vie — John Conway, 1970</p>
      </div>

      <nav class="grid grid-cols-2 md:flex md:flex-row gap-x-10 gap-y-3 md:gap-8 text-sm font-mono text-muted">
        <div class="flex flex-col gap-3 md:contents">
          <a href="/regles" class="hover:text-text transition-colors duration-300">Règles</a>
          <a href="/histoire" class="hover:text-text transition-colors duration-300">Histoire</a>
        </div>
        <div class="flex flex-col gap-3 md:contents">
          <a href="/patterns" class="hover:text-text transition-colors duration-300">Patterns</a>
          <a href="/jeu" class="text-accent hover:opacity-80 transition-opacity duration-300">Simuler →</a>
        </div>
      </nav>
    </div>

    <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-muted text-xs font-mono">© 2025 — Automate cellulaire. Tous droits réservés.</p>
      <a href="/mentions-legales" class="text-muted text-xs font-mono hover:text-text transition-colors duration-300 underline underline-offset-4">
        Mentions légales
      </a>
    </div>

  </div>
</footer>
