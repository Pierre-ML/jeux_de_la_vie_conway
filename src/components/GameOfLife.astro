---
---

<div class="game-wrapper" style="position:relative; width:100%; height:calc(100vh - 4rem); overflow:hidden;">
  <canvas id="gol-canvas" style="display:block; width:100%; height:100%;"></canvas>

  <!-- Tooltip espace -->
  <div id="nav-tooltip" style="
    position:absolute; top:1rem; left:50%; transform:translateX(-50%);
    background:rgba(16,16,16,0.9); border:1px solid #2a2a2a;
    padding:0.4rem 0.9rem; border-radius:3px;
    font-family:'Space Mono',monospace; font-size:0.65rem; color:#888;
    letter-spacing:0.08em; text-transform:uppercase; white-space:nowrap;
    opacity:0; transition:opacity 0.2s; pointer-events:none; z-index:20;
  ">Espace maintenu — mode déplacement</div>

  <!-- HUD bottom bar -->
  <div id="hud" style="
    position:fixed; bottom:0; left:0; right:0; z-index:30;
    background:rgba(16,16,16,0.92); backdrop-filter:blur(12px);
    border-top:1px solid #2a2a2a; padding:0.75rem 1.5rem;
    display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
  ">

    <!-- Boutons de contrôle -->
    <div style="display:flex; gap:0.5rem; align-items:center;">
      <button id="btn-play" title="Lancer (P)" class="hud-btn">▶</button>
      <button id="btn-pause" title="Pause (P)" class="hud-btn" style="display:none;">⏸</button>
      <button id="btn-reset" title="Réinitialiser (R)" class="hud-btn">↺</button>
      <button id="btn-random" title="Remplissage aléatoire" class="hud-btn">⚂</button>
      <button id="btn-center" title="Centrer la vue" class="hud-btn">⊙</button>
    </div>

    <div class="hud-sep"></div>

    <!-- Vitesse -->
    <div style="display:flex; align-items:center; gap:0.75rem;">
      <span class="hud-label">Vitesse</span>
      <input id="speed-slider" type="range" min="1" max="60" value="10"
        style="width:90px; accent-color:#e8ff00; cursor:pointer;" />
      <span id="speed-val" class="hud-value" style="min-width:3rem;">10 fps</span>
    </div>

    <div class="hud-sep"></div>

    <!-- Stats -->
    <div style="display:flex; gap:1.25rem; align-items:center;">
      <div class="hud-stat">
        <span class="hud-label">Génération</span>
        <span id="gen-count" class="hud-value">0</span>
      </div>
      <div class="hud-stat">
        <span class="hud-label">Cellules</span>
        <span id="cell-count" class="hud-value" style="color:#e8ff00;">0</span>
      </div>
      <div class="hud-stat">
        <span class="hud-label">Zoom</span>
        <span id="zoom-level" class="hud-value">16px</span>
      </div>
    </div>

    <!-- Aide navigation (desktop) -->
    <div style="display:none; gap:1.25rem; margin-left:auto;" class="hud-hints md-flex">
      <span class="hud-label">Clic droit / Espace = déplacer &nbsp;·&nbsp; Molette = zoom &nbsp;·&nbsp; P = pause &nbsp;·&nbsp; N = étape</span>
    </div>

    <!-- Statut -->
    <div style="margin-left:auto; display:flex; align-items:center; gap:0.5rem;">
      <div id="status-dot" style="width:6px;height:6px;border-radius:50%;background:#888;transition:background 0.3s;flex-shrink:0;"></div>
      <span id="status-text" class="hud-label" style="letter-spacing:0.1em;">Pause</span>
    </div>
  </div>
</div>

<style>
  .hud-btn {
    width: 2.5rem; height: 2.5rem;
    border: 1px solid #2a2a2a; background: #1a1a1a; color: #f0f0f0;
    border-radius: 3px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.2s, color 0.2s; font-size: 1rem;
    font-family: inherit;
  }
  .hud-btn:hover { border-color: #e8ff00; color: #e8ff00; }

  .hud-sep {
    width: 1px; height: 2rem; background: #2a2a2a; flex-shrink: 0;
  }

  .hud-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem; color: #888;
    text-transform: uppercase; letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .hud-value {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem; color: #f0f0f0; font-weight: 700;
    display: block;
  }

  .hud-stat {
    display: flex; flex-direction: column;
  }

  #nav-tooltip.visible {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .hud-hints { display: flex !important; }
  }
</style>

<script is:inline src="/js/game-of-life.js" defer></script>
