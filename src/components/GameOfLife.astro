---
import '../styles/game.css';
---

<div class="relative w-full h-[calc(100vh-4rem)] overflow-hidden">
  <canvas id="gol-canvas" class="block w-full h-full"></canvas>

  <!-- Tooltip espace -->
  <div id="nav-tooltip" class="absolute top-4 left-1/2 -translate-x-1/2 bg-[rgba(16,16,16,0.9)] border border-[#2a2a2a] px-4 py-1.5 rounded-sm font-mono text-[0.65rem] text-[#888] uppercase tracking-[0.08em] whitespace-nowrap opacity-0 transition-opacity duration-200 pointer-events-none z-20">
    Espace maintenu — mode déplacement
  </div>

  <!-- HUD -->
  <div id="hud" class="fixed bottom-0 left-0 right-0 z-30 bg-[rgba(16,16,16,0.92)] backdrop-blur-xl border-t border-[#2a2a2a] px-6 py-3 flex items-center gap-4 flex-wrap">

    <!-- Boutons -->
    <div class="flex gap-2 items-center">
      <button id="btn-play"   title="Lancer (P)"            class="hud-btn">▶</button>
      <button id="btn-pause"  title="Pause (P)"             class="hud-btn" style="display:none">⏸</button>
      <button id="btn-reset"  title="Réinitialiser (R)"     class="hud-btn">↺</button>
      <button id="btn-random" title="Remplissage aléatoire" class="hud-btn">⚂</button>
      <button id="btn-center" title="Centrer la vue"        class="hud-btn">⊙</button>
    </div>

    <div class="w-px h-8 bg-[#2a2a2a] flex-shrink-0"></div>

    <!-- Vitesse -->
    <div class="flex items-center gap-3">
      <span class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em] whitespace-nowrap">Vitesse</span>
      <input id="speed-slider" type="range" min="1" max="60" value="10" class="w-[90px] accent-[#e8ff00] cursor-pointer" />
      <span id="speed-val" class="font-mono text-[0.85rem] text-[#e8ff00] font-bold min-w-[3rem]">10 fps</span>
    </div>

    <div class="w-px h-8 bg-[#2a2a2a] flex-shrink-0"></div>

    <!-- Stats -->
    <div class="flex gap-5 items-center">
      <div class="flex flex-col">
        <span class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em]">Génération</span>
        <span id="gen-count" class="font-mono text-[0.85rem] text-[#f0f0f0] font-bold">0</span>
      </div>
      <div class="flex flex-col">
        <span class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em]">Cellules</span>
        <span id="cell-count" class="font-mono text-[0.85rem] text-[#e8ff00] font-bold">0</span>
      </div>
      <div class="flex flex-col">
        <span class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em]">Zoom</span>
        <span id="zoom-level" class="font-mono text-[0.85rem] text-[#f0f0f0] font-bold">16px</span>
      </div>
    </div>

    <!-- Aide (desktop uniquement) -->
    <div class="ml-auto hidden md:flex">
      <span class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em] whitespace-nowrap">
        Clic droit / Espace = déplacer &nbsp;·&nbsp; Molette = zoom &nbsp;·&nbsp; P = pause &nbsp;·&nbsp; N = étape
      </span>
    </div>

    <!-- Statut -->
    <div class="ml-auto flex items-center gap-2">
      <div id="status-dot" class="w-1.5 h-1.5 rounded-full bg-[#888] transition-colors duration-300 flex-shrink-0"></div>
      <span id="status-text" class="font-mono text-[0.6rem] text-[#888] uppercase tracking-[0.1em]">Pause</span>
    </div>

  </div>
</div>

<script>
  import '../js/game-of-life.js';
</script>
