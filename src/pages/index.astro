---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Le Jeu de la Vie" page="home">

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-6 md:px-12 pt-24 pb-16 max-w-6xl mx-auto">
    <div class="fade-in">
      <span class="inline-block font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase mb-6 border border-[var(--color-accent)]/30 px-3 py-1 rounded-sm">
        Automate cellulaire — 1970
      </span>
    </div>
    <h1 class="fade-in fade-in-delay-1 text-6xl md:text-8xl lg:text-[9rem] font-bold leading-[0.9] tracking-tight mb-8 text-[var(--color-text)]">
      Le Jeu<br />
      <span class="text-[var(--color-accent)]">de la Vie</span>
    </h1>
    <p class="fade-in fade-in-delay-2 text-[var(--color-muted)] text-lg md:text-xl max-w-xl leading-relaxed mb-12 font-light">
      Un univers infini gouverné par quatre règles simples. Des cellules naissent, survivent et meurent — et de ce chaos émergent des structures d'une complexité stupéfiante.
    </p>
    <div class="fade-in fade-in-delay-3 flex flex-col sm:flex-row gap-4">
      <a href="/jeu" class="group inline-flex items-center gap-3 bg-[var(--color-accent)] text-[var(--color-bg)] px-7 py-3.5 font-mono font-bold text-sm tracking-wide hover:bg-white transition-all duration-300 rounded-sm">
        Lancer la simulation
        <svg class="group-hover:translate-x-1 transition-transform duration-300" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#regles" class="inline-flex items-center gap-3 border border-[var(--color-border)] text-[var(--color-muted)] px-7 py-3.5 font-mono text-sm tracking-wide hover:border-[var(--color-text)] hover:text-[var(--color-text)] transition-all duration-300 rounded-sm">
        Découvrir les règles
      </a>
    </div>

    <div class="mt-24 grid grid-cols-3 gap-8 border-t border-[var(--color-border)] pt-12 fade-in fade-in-delay-4">
      <div>
        <p class="text-4xl font-bold text-[var(--color-text)] mb-1">4</p>
        <p class="text-[var(--color-muted)] text-sm font-mono">Règles</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-[var(--color-text)] mb-1">∞</p>
        <p class="text-[var(--color-muted)] text-sm font-mono">Possibilités</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-[var(--color-text)] mb-1">1970</p>
        <p class="text-[var(--color-muted)] text-sm font-mono">Origine</p>
      </div>
    </div>
  </section>

  <!-- RÈGLES -->
  <section id="regles" class="py-32 px-6 md:px-12 max-w-6xl mx-auto">
    <div class="mb-16 fade-in">
      <span class="font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase">01 — Les règles</span>
      <h2 class="text-5xl md:text-6xl font-bold mt-4 leading-tight">Quatre lois<br />immuables</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="fade-in fade-in-delay-1 border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-8 rounded-sm hover:border-[var(--color-accent)]/40 transition-all duration-300 group">
        <div class="w-10 h-10 border border-[var(--color-accent)]/30 rounded-sm flex items-center justify-center mb-6 group-hover:border-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-accent)] font-mono font-bold text-sm">01</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[var(--color-text)]">Naissance</h3>
        <p class="text-[var(--color-muted)] leading-relaxed">Une cellule <strong class="text-[var(--color-text)]">morte</strong> avec exactement <strong class="text-[var(--color-accent)]">3 voisines vivantes</strong> devient vivante à la prochaine génération.</p>
      </div>

      <div class="fade-in fade-in-delay-2 border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-8 rounded-sm hover:border-[var(--color-accent)]/40 transition-all duration-300 group">
        <div class="w-10 h-10 border border-[var(--color-accent)]/30 rounded-sm flex items-center justify-center mb-6 group-hover:border-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-accent)] font-mono font-bold text-sm">02</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[var(--color-text)]">Survie</h3>
        <p class="text-[var(--color-muted)] leading-relaxed">Une cellule <strong class="text-[var(--color-text)]">vivante</strong> avec <strong class="text-[var(--color-accent)]">2 ou 3 voisines vivantes</strong> survit et reste en vie à la génération suivante.</p>
      </div>

      <div class="fade-in fade-in-delay-3 border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-8 rounded-sm hover:border-[var(--color-accent)]/40 transition-all duration-300 group">
        <div class="w-10 h-10 border border-[var(--color-accent)]/30 rounded-sm flex items-center justify-center mb-6 group-hover:border-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-accent)] font-mono font-bold text-sm">03</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[var(--color-text)]">Surpopulation</h3>
        <p class="text-[var(--color-muted)] leading-relaxed">Une cellule <strong class="text-[var(--color-text)]">vivante</strong> avec <strong class="text-[var(--color-accent)]">plus de 3 voisines</strong> meurt par surpopulation.</p>
      </div>

      <div class="fade-in fade-in-delay-4 border border-[var(--color-border)] bg-[var(--color-surface)]/50 p-8 rounded-sm hover:border-[var(--color-accent)]/40 transition-all duration-300 group">
        <div class="w-10 h-10 border border-[var(--color-accent)]/30 rounded-sm flex items-center justify-center mb-6 group-hover:border-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-accent)] font-mono font-bold text-sm">04</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-[var(--color-text)]">Isolement</h3>
        <p class="text-[var(--color-muted)] leading-relaxed">Une cellule <strong class="text-[var(--color-text)]">vivante</strong> avec <strong class="text-[var(--color-accent)]">moins de 2 voisines</strong> meurt par sous-population.</p>
      </div>
    </div>
  </section>

  <!-- HISTOIRE -->
  <section id="histoire" class="py-32 px-6 md:px-12 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="fade-in font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase">02 — Histoire</span>
        <h2 class="fade-in fade-in-delay-1 text-5xl md:text-6xl font-bold mt-4 leading-tight mb-8">John Conway<br /><span class="text-[var(--color-muted)]">1937 — 2020</span></h2>
        <div class="fade-in fade-in-delay-2 space-y-5 text-[var(--color-muted)] leading-relaxed">
          <p>
            John Horton Conway était un mathématicien britannique de renom, professeur à l'Université de Cambridge puis à Princeton. Passionné par les jeux et les puzzles mathématiques, il a révolutionné plusieurs domaines des mathématiques.
          </p>
          <p>
            En <strong class="text-[var(--color-text)]">octobre 1970</strong>, il publie dans la revue <em>Scientific American</em> son automate cellulaire baptisé <strong class="text-[var(--color-text)]">Game of Life</strong>. Conçu à partir d'un simple échiquier et de quatre règles, il fascine immédiatement la communauté scientifique et informatique.
          </p>
          <p>
            Le jeu démontre qu'une <strong class="text-[var(--color-text)]">complexité infinie</strong> peut émerger de règles d'une simplicité absolue — un concept fondateur en théorie de la complexité et en informatique théorique.
          </p>
        </div>
      </div>

      <div class="fade-in fade-in-delay-3">
        <div class="border border-[var(--color-border)] bg-[var(--color-surface)]/30 p-8 rounded-sm">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 rounded-sm flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L2 7v11h16V7L10 2z" stroke="#e8ff00" stroke-width="1.2"/><path d="M7 18v-7h6v7" stroke="#e8ff00" stroke-width="1.2"/></svg>
            </div>
            <div>
              <p class="font-bold text-[var(--color-text)]">Turing-complet</p>
              <p class="text-[var(--color-muted)] text-sm mt-1">Le Game of Life peut simuler n'importe quel ordinateur. Il est Turing-complet — capable de résoudre tout problème calculable.</p>
            </div>
          </div>
          <div class="h-px bg-[var(--color-border)] my-6"></div>
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 rounded-sm flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="#e8ff00" stroke-width="1.2"/><path d="M10 6v4l3 3" stroke="#e8ff00" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
            <div>
              <p class="font-bold text-[var(--color-text)]">Pas de déterminisme apparent</p>
              <p class="text-[var(--color-muted)] text-sm mt-1">Malgré ses règles strictement déterministes, prédire l'évolution d'un pattern arbitraire est mathématiquement impossible (indécidable).</p>
            </div>
          </div>
          <div class="h-px bg-[var(--color-border)] my-6"></div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 rounded-sm flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2 10h16M10 2v16" stroke="#e8ff00" stroke-width="1.2" stroke-linecap="round"/><rect x="6" y="6" width="8" height="8" stroke="#e8ff00" stroke-width="1.2"/></svg>
            </div>
            <div>
              <p class="font-bold text-[var(--color-text)]">Grille infinie</p>
              <p class="text-[var(--color-muted)] text-sm mt-1">Théoriquement, la grille est infinie dans toutes les directions. Des patterns peuvent se déplacer indéfiniment.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PATTERNS -->
  <section id="patterns" class="py-32 px-6 md:px-12 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16 fade-in">
        <span class="font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase">03 — Patterns célèbres</span>
        <h2 class="text-5xl md:text-6xl font-bold mt-4 leading-tight">Structures<br />remarquables</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Glider -->
        <div class="fade-in fade-in-delay-1 border border-[var(--color-border)] bg-[var(--color-surface)]/30 p-8 rounded-sm hover:border-[var(--color-border)]/80 transition-all duration-300">
          <div class="mb-6">
            <div class="font-mono text-[var(--color-accent)] text-xs mb-4 tracking-wider">GLIDER</div>
            <div class="font-mono text-sm leading-tight text-[var(--color-text)] bg-[var(--color-bg)] p-4 rounded-sm border border-[var(--color-border)]">
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1">
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
              </div>
            </div>
          </div>
          <h3 class="font-bold text-lg mb-2">Glider</h3>
          <p class="text-[var(--color-muted)] text-sm leading-relaxed">Le plus célèbre des patterns mobiles. Se déplace en diagonale à travers la grille, se reproduisant toutes les 4 générations.</p>
          <p class="text-[var(--color-accent)] font-mono text-xs mt-4">5 cellules · Oscille / se déplace</p>
        </div>

        <!-- Blinker -->
        <div class="fade-in fade-in-delay-2 border border-[var(--color-border)] bg-[var(--color-surface)]/30 p-8 rounded-sm hover:border-[var(--color-border)]/80 transition-all duration-300">
          <div class="mb-6">
            <div class="font-mono text-[var(--color-accent)] text-xs mb-4 tracking-wider">BLINKER</div>
            <div class="font-mono text-sm leading-tight text-[var(--color-text)] bg-[var(--color-bg)] p-4 rounded-sm border border-[var(--color-border)]">
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
            </div>
          </div>
          <h3 class="font-bold text-lg mb-2">Blinker</h3>
          <p class="text-[var(--color-muted)] text-sm leading-relaxed">L'oscillateur le plus simple. Alterne entre une ligne horizontale et une ligne verticale de 3 cellules, avec une période de 2.</p>
          <p class="text-[var(--color-accent)] font-mono text-xs mt-4">3 cellules · Période 2</p>
        </div>

        <!-- Block -->
        <div class="fade-in fade-in-delay-3 border border-[var(--color-border)] bg-[var(--color-surface)]/30 p-8 rounded-sm hover:border-[var(--color-border)]/80 transition-all duration-300">
          <div class="mb-6">
            <div class="font-mono text-[var(--color-accent)] text-xs mb-4 tracking-wider">BLOCK</div>
            <div class="font-mono text-sm leading-tight text-[var(--color-text)] bg-[var(--color-bg)] p-4 rounded-sm border border-[var(--color-border)]">
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1 mb-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-[var(--color-accent)] rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
              <div class="flex gap-1">
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
                <span class="w-4 h-4 bg-transparent border border-[var(--color-border)]/50 rounded-sm inline-block"></span>
              </div>
            </div>
          </div>
          <h3 class="font-bold text-lg mb-2">Block</h3>
          <p class="text-[var(--color-muted)] text-sm leading-relaxed">La structure stable la plus simple. Un carré 2×2 de cellules vivantes qui reste identique à travers les générations, à l'équilibre parfait.</p>
          <p class="text-[var(--color-accent)] font-mono text-xs mt-4">4 cellules · Still life</p>
        </div>

      </div>

      <div class="mt-16 text-center fade-in">
        <a href="/jeu" class="group inline-flex items-center gap-3 bg-[var(--color-accent)] text-[var(--color-bg)] px-8 py-4 font-mono font-bold text-sm tracking-wide hover:bg-white transition-all duration-300 rounded-sm">
          Explorer la simulation
          <svg class="group-hover:translate-x-1 transition-transform duration-300" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
