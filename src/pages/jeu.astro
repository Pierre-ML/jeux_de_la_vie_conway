---
import Layout from '../layouts/Layout.astro';
import GameOfLife from '../components/GameOfLife.astro';
---

<Layout
  title="Simulation — Le Jeu de la Vie"
  description="Simulateur interactif du Jeu de la Vie de John Conway"
  page="game"
  noFooter={true}
>
  <div style="padding-top:4rem; height:100vh; overflow:hidden; background:#101010;">
    <GameOfLife />
  </div>
</Layout>

<style>
  body {
    overflow: hidden;
  }
</style>

